{
  "name": "ocr-for-all",
  "displayName": "OCR for ALL: AI Image to Text, PDF, LaTeX Math, Table & Invoice Parser",
  "description": "Ultra-high accuracy AI OCR. Convert images, screenshots, scans, handwritten notes, LaTeX math formulas, tables, and PDFs to clean Markdown, LaTeX, or JSON directly in VSCode using Gemini, Claude & GPT-4o.",
  "version": "1.0.3",
  "publisher": "ocr-for-all",
  "repository": {
    "type": "git",
    "url": "https://github.com/vajrainternationalexports-byte/OCR.git"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Formatters",
    "Data Science",
    "Education",
    "Other"
  ],
  "keywords": [
    "ocr",
    "image-to-text",
    "pdf-to-text",
    "latex-math",
    "invoice-parser",
    "ai-ocr",
    "gemini",
    "claude",
    "gpt-4o",
    "screenshot-ocr",
    "handwriting-ocr",
    "table-extractor"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onCommand:ocr-for-all.startServer",
    "onCommand:ocr-for-all.stopServer",
    "onCommand:ocr-for-all.runOcrOnFile",
    "onView:ocr-for-all-sidebar"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ocr-for-all-container",
          "title": "OCR for ALL",
          "icon": "$(eye)"
        }
      ]
    },
    "views": {
      "ocr-for-all-container": [
        {
          "id": "ocr-for-all-sidebar",
          "type": "webview",
          "name": "OCR for ALL Panel"
        }
      ]
    },
    "commands": [
      {
        "command": "ocr-for-all.startServer",
        "title": "OCR for ALL: Start Server",
        "category": "OCR for ALL"
      },
      {
        "command": "ocr-for-all.stopServer",
        "title": "OCR for ALL: Stop Server",
        "category": "OCR for ALL"
      },
      {
        "command": "ocr-for-all.runOcrOnFile",
        "title": "OCR for ALL: Run OCR on File...",
        "category": "OCR for ALL"
      }
    ],
    "configuration": {
      "title": "OCR for ALL",
      "properties": {
        "ocr-for-all.provider": {
          "type": "string",
          "enum": [
            "Gemini",
            "Claude 3.5 Sonnet",
            "OpenAI GPT-4o",
            "Custom OpenAI-Compatible"
          ],
          "default": "Gemini",
          "description": "AI provider model to use for the vision OCR operations."
        },
        "ocr-for-all.apiEndpoint": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "API base endpoint. Custom OpenAI-compatible endpoints can be set here."
        },
        "ocr-for-all.apiModel": {
          "type": "string",
          "default": "gemini-3.5-flash",
          "description": "Specific model identifier (e.g. gemini-3.5-flash, claude-3-5-sonnet-20241022, gpt-4o)."
        },
        "ocr-for-all.apiKey": {
          "type": "string",
          "default": "",
          "description": "API Key for your chosen provider. (⚠️ Stored in VSCode configuration plaintext)."
        },
        "ocr-for-all.port": {
          "type": "integer",
          "default": 50906,
          "description": "Port to run the local OCR proxy server on (default is 50906)."
        },
        "ocr-for-all.ocrMode": {
          "type": "string",
          "enum": [
            "STANDARD",
            "MARKDOWN",
            "LATEX",
            "TABLE",
            "INVOICE_JSON",
            "AUTO_DETECT"
          ],
          "default": "STANDARD",
          "description": "The default parsing mode for OCR conversions."
        },
        "ocr-for-all.contextLineRadius": {
          "type": "integer",
          "default": 20,
          "description": "Number of lines surrounding the cursor in the active document to include as context for the OCR model."
        },
        "ocr-for-all.contextCharLimit": {
          "type": "integer",
          "default": 2000,
          "description": "Maximum character length of document context to include in prompt."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && mkdir -p out/locales && cp -R src/locales/ out/locales/",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "bonjour-service": "^1.1.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^16.11.7",
    "@types/express": "^4.17.17",
    "@types/cors": "^2.8.13",
    "typescript": "^4.9.5"
  }
}
